"""
login_page.py
Page Object for https://v2.zenclass.in/ (login screen).
"""
from selenium.webdriver.common.by import By
from pages.base_page import BasePage

BASE_URL = "https://v2.zenclass.in/"


class LoginPage(BasePage):
    USERNAME_INPUT = (By.XPATH, '//*[@id=":r1:"]')
    PASSWORD_INPUT = (By.XPATH, '//*[@id=":r2:"]')
    LOGIN_BUTTON = (By.XPATH, '//*[@id="root"]/div[2]/div/div/div[2]/div/div/div[3]/div/div/form/div[4]/button')
    ERROR_MESSAGE = (By.XPATH, '//*[@id=":r2:-helper-text"]')

    def load(self):
        self.open(BASE_URL)

    def login(self, username, password):
        self.type_text(self.USERNAME_INPUT, username)
        self.type_text(self.PASSWORD_INPUT, password)
        self.click(self.LOGIN_BUTTON)

    def get_error_message(self):
        return self.get_text(self.ERROR_MESSAGE)

    def is_error_displayed(self):
        return self.is_visible(self.ERROR_MESSAGE, timeout=3)
