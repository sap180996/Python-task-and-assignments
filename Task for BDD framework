"""
dashboard_page.py
Page Object for https://v2.zenclass.in/ (Dashboard screen with logout functionality).
"""
from selenium.webdriver.common.by import By
from pages.base_page import BasePage
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC


class DashboardPage(BasePage):
    MODAL_CLOSE_BUTTON = (By.XPATH,
                          "//button[contains(@class, 'close')] | //*[local-name()='svg' and @data-testid='CloseIcon']/..")
    MUI_BACKDROP = (By.CLASS_NAME, "MuiBackdrop-root")


    USER_MENU_DROPDOWN = (By.CSS_SELECTOR, ".profile-click-icon-div")
    LOGOUT_BUTTON = (By.XPATH, '//*[@id="root"]/div[2]/div[2]/div[1]/div/div[2]/div[2]/div[2]/div[4]')

    def is_dashboard_visible(self):
        try:
            # Notice we use 'self.driver' here, NOT context.driver
            WebDriverWait(self.driver, 15).until(
                EC.visibility_of_element_located(self.USER_MENU_DROPDOWN)
            )
            return True
        except:
            return False

    def click_user_menu(self):
        element = self.find_clickable(self.USER_MENU_DROPDOWN)
        self.driver.execute_script("arguments[0].click();", element)

    def click_logout(self):
        element = self.find_clickable(self.LOGOUT_BUTTON)
        self.driver.execute_script("arguments[0].click();", element)

    def logout(self):
        self.click_user_menu()
        self.click_logout()

    class BasePage:
        MUI_BACKDROP = (By.CLASS_NAME, "MuiBackdrop-root")

        def wait_for_overlay_to_disappear(self, timeout=10):
            try:
                WebDriverWait(self.driver, timeout).until(
                    EC.invisibilityOfElementLocated(self.MUI_BACKDROP)
                )
            except Exception:
                pass

    def handle_announcement_modal(self):
        try:
            WebDriverWait(self.driver, 5).until(
                EC.visibility_of_element_located(self.MODAL_CLOSE_BUTTON)
            )
            self.click(self.MODAL_CLOSE_BUTTON)

            WebDriverWait(self.driver, 5).until(
                EC.invisibility_of_element_located(self.MUI_BACKDROP)
            )
        except Exception:
            print("No modal overlay detected. Proceeding...")
